+	if (EVP_PKEY_set1_RSA(pkey, rsa) != 1) {
+		plog(LLV_ERROR, LOCATION, NULL, "EVP_PKEY_set1_RSA failed\n");
+		EVP_PKEY_free(pkey);
+		return -1;
+	}
+#endif
+
+	/* Perform verification using EVP_PKEY wrapper */
+	res = eay_pkey_verify(source, sig, pkey);
+
+	EVP_PKEY_free(pkey);
+	return res;
 }
 
