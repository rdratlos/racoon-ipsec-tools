+	encoded = base64_encode(test_data, strlen(test_data));
+	if (!encoded) TEST_FAIL("Base64 encode failed");
+
+	/* Verify encoded is different and larger */
+	if (encoded->l <= strlen(test_data)) {
+		TEST_FAIL("Base64 encoded not larger than original");
+	}
+
+	/* Decode */
+	decoded = base64_decode((char *)encoded->v, encoded->l);
+	if (!decoded) TEST_FAIL("Base64 decode failed");
+
+	/* Verify decoded matches original */
+	if (decoded->l != strlen(test_data)) {
+		TEST_FAIL("Base64 decoded length wrong");
+	}
+
+	if (memcmp(decoded->v, test_data, strlen(test_data)) != 0) {
+		TEST_FAIL("Base64 decoded data doesn't match");
+	}
+
+	printf("Base64 encode/decode cycle OK ");
+	ret = 0;
+
+	if (encoded) vfree(encoded);
+	if (decoded) vfree(decoded);
+
+	if (ret == 0) TEST_PASS();
+	return ret;
+}
