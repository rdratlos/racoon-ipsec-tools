+int test_base64_various_sizes()
+{
+	int sizes[] = {1, 10, 50, 100, 1000};
+	int i;
+	int ret = -1;
+
+	TEST_START("Base64 with Various Data Sizes");
+	printf("\n");
+
+	for (i = 0; i < 5; i++) {
+		vchar_t *encoded = NULL, *decoded = NULL;
+		char *data = NULL;
+		int j;
+
+		printf("    Size %d bytes... ", sizes[i]);
+		fflush(stdout);
+
+		/* Create test data */
+		data = malloc(sizes[i]);
+		if (!data) {
+			printf("FAIL (alloc)\n");
+			continue;
+		}
+		for (j = 0; j < sizes[i]; j++) {
+			data[j] = (char)(j & 0xFF);
+		}
+
+		/* Encode */
+		encoded = base64_encode(data, sizes[i]);
+		if (!encoded) {
+			printf("FAIL (encode)\n");
+			free(data);
+			continue;
+		}
+
+		/* Decode */
+		decoded = base64_decode((char *)encoded->v, encoded->l);
+		if (!decoded) {
+			printf("FAIL (decode)\n");
+			free(data);
+			vfree(encoded);
+			continue;
+		}
+
+		/* Verify */
+		if (decoded->l != sizes[i] || memcmp(decoded->v, data, sizes[i]) != 0) {
+			printf("FAIL (mismatch)\n");
+			free(data);
+			vfree(encoded);
+			vfree(decoded);
+			continue;
+		}
+
+		printf("✓ OK\n");
+		free(data);
+		vfree(encoded);
+		vfree(decoded);
+	}
+
+	printf("    ");
