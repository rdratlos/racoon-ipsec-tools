+	TEST_START("DH Key Generation - All 8 MODP Groups");
+	printf("\n");
+
+	for (i = 0; i < num_groups; i++) {
+		vchar_t *prime = NULL;
+		vchar_t *pub = NULL, *priv = NULL;
+		BIGNUM *bn = NULL;
+
+		printf("    %s (%d bytes)... ",
+		       modp_groups[i].name, modp_groups[i].expected_bytes);
+		fflush(stdout);
+
+		/* Convert hex prime to vchar_t */
+		prime = vmalloc(sizeof(vchar_t));
+		if (!prime) {
+			printf("FAIL (allocation)\n");
+			failed++;
+			continue;
+		}
+		prime->v = str2val(modp_groups[i].prime_hex, 16, &prime->l);
+		if (!prime->v) {
+			printf("FAIL (prime conversion)\n");
+			vfree(prime);
+			failed++;
+			continue;
+		}
+
+		/* Generate key pair */
+		if (eay_dh_generate(prime, modp_groups[i].generator, test_dh_bits, &pub, &priv) != 0) {
+			printf("FAIL (keygen)\n");
+			vfree(prime);
+			failed++;
