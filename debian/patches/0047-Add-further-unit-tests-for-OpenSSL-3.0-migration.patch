+/*
+ * NOTE: In real IPsec/IKE usage, RSA signatures are only used on hashes
+ * (20-64 bytes), never on large payloads. Per RFC 2409, authentication
+ * data is always hashed before signing. This test verifies the maximum
+ * size limit is enforced correctly for direct RSA operations.
+ */
+int test_rsa_maximum_data_size()
+{
+	EVP_PKEY_CTX *ctx = NULL;
+	EVP_PKEY *pkey = NULL;
+	RSA *rsa = NULL;
+	vchar_t *data = NULL, *signature = NULL;
+	int ret = -1;
+	size_t max_size;  // Will calculate based on key size
+	size_t i;
+
+	TEST_START("RSA with Maximum Data Size");
+
+	/* Generate key */
+	ctx = EVP_PKEY_CTX_new_from_name(NULL, "RSA", NULL);
+	if (!ctx || EVP_PKEY_keygen_init(ctx) <= 0 ||
+	    EVP_PKEY_CTX_set_rsa_keygen_bits(ctx, 2048) <= 0 ||
+	    EVP_PKEY_keygen(ctx, &pkey) <= 0) {
+		TEST_FAIL("Key generation failed");
+	}
+
+	rsa = EVP_PKEY_get1_RSA(pkey);
+	if (!rsa) {
+		TEST_FAIL("Failed to extract RSA");
+	}
+
+	/* Calculate maximum data size for PKCS#1 v1.5 padding */
+	/* Formula: key_size_bytes - 11 */
+	max_size = RSA_size(rsa) - 11;  // For 2048-bit key: 256 - 11 = 245 bytes
+	printf("(max data size: %zu bytes for %d-bit key) ", max_size, RSA_bits(rsa));
+
+	/* Create maximum size data buffer */
+	data = vmalloc(max_size);
+	if (!data) {
+		TEST_FAIL("Allocation failed");
+	}
+
+	/* Fill with pattern */
+	for (i = 0; i < max_size; i++) {
+		((unsigned char *)data->v)[i] = (unsigned char)(i & 0xFF);
+	}
+
+	/* Sign and verify */
+	signature = eay_get_rsasign(data, rsa);
+	if (!signature) {
+		TEST_FAIL("Signing maximum-size data failed");
+	}
+
+	if (eay_check_rsasign(data, signature, rsa) != 0) {
+		TEST_FAIL("Verifying maximum-size data failed");
+	}
+
+	printf("Maximum data size (%zu bytes) handled ", max_size);
+	ret = 0;
+
+	if (data) vfree(data);
+	if (signature) vfree(signature);
+	if (rsa) RSA_free(rsa);
+	if (pkey) EVP_PKEY_free(pkey);
+	if (ctx) EVP_PKEY_CTX_free(ctx);
+
+	if (ret == 0) TEST_PASS();
+	return ret;
+}
