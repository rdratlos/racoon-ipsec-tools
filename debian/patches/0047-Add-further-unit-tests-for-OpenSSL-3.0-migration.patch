+int test_rsa_bignum_conversion()
+{
+	EVP_PKEY_CTX *ctx = NULL;
+	EVP_PKEY *pkey = NULL;
+	RSA *rsa1 = NULL, *rsa2 = NULL;
+	BIGNUM *n_copy = NULL;
+	vchar_t *data = NULL, *sig1 = NULL, *sig2 = NULL;
+	int ret = -1;
+
+	TEST_START("RSA BIGNUM Conversion");
+
+	/* Generate key */
+	ctx = EVP_PKEY_CTX_new_from_name(NULL, "RSA", NULL);
+	if (!ctx || EVP_PKEY_keygen_init(ctx) <= 0 ||
+	    EVP_PKEY_CTX_set_rsa_keygen_bits(ctx, 2048) <= 0 ||
+	    EVP_PKEY_keygen(ctx, &pkey) <= 0) {
+		TEST_FAIL("Key generation failed");
+	}
+
+	rsa1 = EVP_PKEY_get1_RSA(pkey);
+	if (!rsa1) {
+		TEST_FAIL("Failed to extract RSA");
+	}
+
+	/* Get modulus */
+	const BIGNUM *n = NULL, *e = NULL;
+	RSA_get0_key(rsa1, &n, &e, NULL);
+	if (!n || !e) {
+		TEST_FAIL("Failed to get modulus");
+	}
+
+	/* Copy modulus */
+	n_copy = BN_dup(n);
+	if (!n_copy) {
+		TEST_FAIL("Failed to duplicate BIGNUM");
+	}
+
+	/* Convert BIGNUM to RSA public key using bignum_pubkey2rsa */
+	rsa2 = bignum_pubkey2rsa(n_copy);
+	if (!rsa2) {
+		TEST_FAIL("bignum_pubkey2rsa() failed");
+	}
+
+	/* Test that we can verify with the reconstructed key */
+	data = vmalloc(strlen(test_data_short));
+	if (!data) {
+		TEST_FAIL("Allocation failed");
+	}
+	memcpy(data->v, test_data_short, strlen(test_data_short));
+
+	sig1 = eay_get_rsasign(data, rsa1);
+	if (!sig1) {
+		TEST_FAIL("Signing with original key failed");
+	}
+
+	/* Note: rsa2 is public key only, can't sign, but can verify */
+	if (eay_check_rsasign(data, sig1, rsa2) != 0) {
+		TEST_FAIL("Verification with reconstructed key failed");
+	}
+
+	printf("BIGNUM→RSA conversion works ");
+	ret = 0;
+
+	if (data) vfree(data);
+	if (sig1) vfree(sig1);
+	if (n_copy) BN_free(n_copy);
+	if (rsa1) RSA_free(rsa1);
+	if (rsa2) RSA_free(rsa2);
+	if (pkey) EVP_PKEY_free(pkey);
+	if (ctx) EVP_PKEY_CTX_free(ctx);
+
+	if (ret == 0) TEST_PASS();
+	return ret;
+}
