+			if (priv) vfree(priv);
+			vfree(prime);
+			failed++;
+			continue;
+		}
+
+		/* Public key should be reasonable size */
+		if (pub->l > prime->l) {
+			printf("FAIL (pub key too large: %zu > %zu)\n", pub->l, prime->l);
+			vfree(pub);
+			vfree(priv);
+			vfree(prime);
+			failed++;
+			continue;
+		}
+
+		printf("✓ OK (pub=%zu, priv=%zu bytes)\n", pub->l, priv->l);
+
+		vfree(pub);
+		vfree(priv);
+		vfree(prime);
+	}
+
+	printf("    ");
