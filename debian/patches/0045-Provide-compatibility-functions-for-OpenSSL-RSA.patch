+/*
+ * binbuf_pubkey2rsa - Convert IPSec/IKE wire format public key to RSA structure
+ *
+ * Parses an RSA public key from IPSec/IKE wire format and creates an RSA
+ * structure suitable for textbook RSA operations (raw encryption/decryption
+ * with PKCS#1 v1.5 padding).
+ *
+ * Wire Format (RFC 2408/2409):
+ *   Byte 0:          Length of exponent in bytes
+ *   Bytes 1..N:      Public exponent (big-endian)
+ *   Bytes (N+1)..end: Modulus (big-endian)
+ *
+ * This format is used in IKEv1 RSASIG authentication where public keys are
+ * exchanged as raw key material rather than X.509 certificates.
+ *
+ * Example wire format for exponent 0x03 and 1024-bit modulus:
+ *   [0x01][0x03][128 bytes of modulus]
+ *
+ * OpenSSL 3.0 Compatibility:
+ *   Uses EVP_PKEY_fromdata() to construct the key, then extracts RSA*
+ *   for compatibility with legacy code expecting RSA structures.
+ *
+ * Parameters:
+ *   binbuf - vchar_t containing the wire format public key
+ *            Must not be NULL and must contain at least 2 bytes
+ *
+ * Returns:
+ *   RSA* - Pointer to RSA structure on success (caller must free with RSA_free)
+ *   NULL - On failure (invalid format, memory allocation failure, or OpenSSL error)
+ *
+ * Error Conditions:
+ *   - First byte (exponent length) exceeds buffer length
+ *   - Memory allocation failure
+ *   - Invalid key parameters
+ *   - OpenSSL 3.0 key construction failure
+ *
+ * Notes:
+ *   - The returned RSA structure supports textbook RSA operations
+ *   - Both common exponents (3, 65537) and arbitrary exponents are supported
+ *   - The function validates that exponent length makes sense relative to buffer size
+ *   - Errors are logged via plog() with detailed OpenSSL error strings
+ *
+ * Security Considerations:
+ *   - No validation of key strength (modulus size, exponent value)
+ *   - Caller must ensure the key comes from a trusted source
+ *   - Small exponents (e.g., 3) are supported but may be cryptographically weak
+ *
+ * Example Usage:
+ *   vchar_t *wire_key = ...; // From IKE message
+ *   RSA *pubkey = binbuf_pubkey2rsa(wire_key);
+ *   if (!pubkey) {
+ *       // Handle error
+ *   }
+ *   // Use pubkey for signature verification
+ *   RSA_free(pubkey);
+ */
 static RSA *
 binbuf_pubkey2rsa(vchar_t *binbuf)
 {
@@ -3276,14 +3328,15 @@ binbuf_pubkey2rsa(vchar_t *binbuf)
 	RSA *rsa_pub = NULL;
 	EVP_PKEY *pkey = NULL;
 	EVP_PKEY_CTX *ctx = NULL;
-	OSSL_PARAM params[3];
-	int ret = -1;
+	OSSL_PARAM_BLD *bld = NULL;
+	OSSL_PARAM *params = NULL;
 
 	if (binbuf->v[0] > binbuf->l - 1) {
 		plog(LLV_ERROR, LOCATION, NULL, "Plain RSA pubkey format error: decoded string doesn't make sense.\n");
 		goto out;
 	}
 
+	/* Parse IPSec format: [exp_len][exponent][modulus] */
 	exp = BN_bin2bn((unsigned char *) (binbuf->v + 1), binbuf->v[0], NULL);
 	mod = BN_bin2bn((unsigned char *) (binbuf->v + binbuf->v[0] + 1),
 			binbuf->l - binbuf->v[0] - 1, NULL);
@@ -3293,33 +3346,31 @@ binbuf_pubkey2rsa(vchar_t *binbuf)
 		goto out;
 	}
 
-	/* Build RSA key using EVP_PKEY */
+	/* Build RSA key using OSSL_PARAM_BLD */
+	bld = OSSL_PARAM_BLD_new();
+	if (!bld)
+		goto out;
+
+	if (!OSSL_PARAM_BLD_push_BN(bld, OSSL_PKEY_PARAM_RSA_N, mod))
+		goto out;
+	if (!OSSL_PARAM_BLD_push_BN(bld, OSSL_PKEY_PARAM_RSA_E, exp))
+		goto out;
+
+	params = OSSL_PARAM_BLD_to_param(bld);
+	if (!params)
+		goto out;
+
 	ctx = EVP_PKEY_CTX_new_from_name(NULL, "RSA", NULL);
 	if (!ctx)
 		goto out;
 
-	params[0] = OSSL_PARAM_construct_BN(OSSL_PKEY_PARAM_RSA_N,
-					    (unsigned char *)mod, BN_num_bytes(mod));
-	params[1] = OSSL_PARAM_construct_BN(OSSL_PKEY_PARAM_RSA_E,
-					    (unsigned char *)exp, BN_num_bytes(exp));
-	params[2] = OSSL_PARAM_construct_end();
-
 	if (EVP_PKEY_fromdata_init(ctx) <= 0)
 		goto out;
 
 	if (EVP_PKEY_fromdata(ctx, &pkey, EVP_PKEY_PUBLIC_KEY, params) <= 0)
 		goto out;
 
-	/* OpenSSL 3.0 deprecated direct RSA structure access in favor of EVP_PKEY.
-	 * However, IPSec standards rely on raw RSA operations (textbook RSA with
-	 * PKCS#1 v1.5 padding), and Racoon's architecture expects RSA* structures.
-	 *
-	 * We use EVP_PKEY_get1_RSA() here because:
-	 * 1. It's functionally correct and maintained by OpenSSL
-	 * 2. Refactoring all IPSec code to use EVP_PKEY would be invasive
-	 * 3. The RSA structure behavior remains identical
-	 * 4. OpenSSL maintains backward compatibility
-	 */
+	/* Extract RSA structure for compatibility with legacy code */
 #pragma GCC diagnostic push
 #pragma GCC diagnostic ignored "-Wdeprecated-declarations"
 	rsa_pub = EVP_PKEY_get1_RSA(pkey);
@@ -3330,6 +3381,10 @@ out:
 		EVP_PKEY_CTX_free(ctx);
 	if (pkey)
 		EVP_PKEY_free(pkey);
+	if (params)
+		OSSL_PARAM_free(params);
+	if (bld)
+		OSSL_PARAM_BLD_free(bld);
 	if (exp)
 		BN_free(exp);
 	if (mod)
@@ -3369,24 +3424,150 @@ out:
 	return rsa_pub;
 }
 
+/*
+ * bignum_pubkey2rsa - Create RSA public key from modulus with standard exponent
+ *
+ * Constructs an RSA public key structure from a modulus BIGNUM, using the
+ * standard public exponent 65537 (0x10001 = RSA_F4). This is a utility
+ * function for cases where only the modulus is known and the standard
+ * exponent can be assumed.
+ *
+ * The standard exponent 65537 is recommended by NIST and widely used because:
+ *   - It's large enough to resist basic attacks
+ *   - It's a Fermat prime (2^16 + 1), making modular exponentiation efficient
+ *   - It's the de facto standard in modern RSA implementations
+ *
+ * Use Cases:
+ *   - Converting certificate modulus to RSA key for verification
+ *   - Testing RSA operations with known modulus
+ *   - Reconstructing public key when exponent is implicit
+ *   - Legacy code migration where only modulus was stored
+ *
+ * OpenSSL 3.0 Compatibility:
+ *   Uses the modern EVP_PKEY API internally, then extracts RSA* for
+ *   compatibility with existing Racoon code that expects RSA structures
+ *   for textbook RSA operations.
+ *
+ * Parameters:
+ *   in - BIGNUM containing the RSA modulus (must not be NULL)
+ *        The modulus is duplicated internally, so caller retains ownership
+ *
+ * Returns:
+ *   RSA* - Pointer to RSA public key structure on success
+ *          Caller must free with RSA_free()
+ *   NULL - On failure (NULL input, memory allocation failure, or OpenSSL error)
+ *
+ * Error Conditions:
+ *   - NULL input BIGNUM
+ *   - BN_dup() failure (memory allocation)
+ *   - Exponent creation failure
+ *   - OpenSSL 3.0 parameter building or key construction failure
+ *
+ * Notes:
+ *   - Input BIGNUM is duplicated; caller retains ownership of original
+ *   - Always uses exponent 65537 (RSA_F4); not configurable
+ *   - No validation of modulus size or cryptographic strength
+ *   - Returned RSA structure supports textbook RSA operations
+ *   - All errors are logged via plog() for debugging
+ *
+ * Security Considerations:
+ *   - Assumes modulus comes from a trusted source
+ *   - Does not validate modulus is a proper RSA modulus (product of two primes)
+ *   - Does not check modulus size (caller should ensure >= 2048 bits for security)
+ *   - Fixed exponent may not be suitable for all applications
+ *
+ * Difference from binbuf_pubkey2rsa():
+ *   - bignum_pubkey2rsa(): Takes BIGNUM modulus, assumes e=65537
+ *   - binbuf_pubkey2rsa(): Parses wire format with both exponent and modulus
+ *
+ * Example Usage:
+ *   const BIGNUM *cert_modulus = ...; // From X.509 certificate
+ *   RSA *pubkey = bignum_pubkey2rsa((BIGNUM *)cert_modulus);
+ *   if (!pubkey) {
+ *       // Handle error
+ *   }
+ *   // Use pubkey for signature verification with textbook RSA
+ *   int result = eay_check_rsasign(data, signature, pubkey);
+ *   RSA_free(pubkey);
+ *
+ * Design Rationale:
+ *   This function exists because Racoon's architecture expects RSA* structures
+ *   for textbook RSA operations, but may only have the modulus available from
+ *   certain sources (certificates, stored keys, etc.). Rather than requiring
+ *   full key material, this function fills in the standard exponent.
+ */
 RSA *
 bignum_pubkey2rsa(BIGNUM *in)
 {
 	RSA *rsa_pub = NULL;
-	vchar_t *binbuf;
+	BIGNUM *n = NULL, *e = NULL;
+	EVP_PKEY *pkey = NULL;
+	EVP_PKEY_CTX *ctx = NULL;
+	OSSL_PARAM_BLD *bld = NULL;
+	OSSL_PARAM *params = NULL;
 
-	binbuf = vmalloc(BN_num_bytes(in));
-	if (!binbuf) {
-		plog(LLV_ERROR, LOCATION, NULL, "Plain RSA pubkey conversion: memory allocation failed..\n");
+	if (!in) {
+		plog(LLV_ERROR, LOCATION, NULL, "bignum_pubkey2rsa: NULL BIGNUM\n");
 		return NULL;
 	}
 
-	BN_bn2bin(in, (unsigned char *) binbuf->v);
+	/* Duplicate the modulus */
+	n = BN_dup(in);
+	if (!n) {
+		plog(LLV_ERROR, LOCATION, NULL, "bignum_pubkey2rsa: BN_dup failed\n");
+		return NULL;
+	}
 
-	rsa_pub = binbuf_pubkey2rsa(binbuf);
+	/* Create standard public exponent (65537 = RSA_F4) */
+	e = BN_new();
+	if (!e || !BN_set_word(e, RSA_F4)) {
+		plog(LLV_ERROR, LOCATION, NULL, "bignum_pubkey2rsa: Failed to create exponent\n");
+		goto out;
+	}
 
-	if (binbuf)
-		vfree(binbuf);
+	/* Build RSA key using OSSL_PARAM_BLD */
+	bld = OSSL_PARAM_BLD_new();
+	if (!bld)
+		goto out;
+
+	if (!OSSL_PARAM_BLD_push_BN(bld, OSSL_PKEY_PARAM_RSA_N, n))
+		goto out;
+	if (!OSSL_PARAM_BLD_push_BN(bld, OSSL_PKEY_PARAM_RSA_E, e))
+		goto out;
+
+	params = OSSL_PARAM_BLD_to_param(bld);
+	if (!params)
+		goto out;
+
+	ctx = EVP_PKEY_CTX_new_from_name(NULL, "RSA", NULL);
+	if (!ctx)
+		goto out;
+
+	if (EVP_PKEY_fromdata_init(ctx) <= 0)
+		goto out;
+
+	if (EVP_PKEY_fromdata(ctx, &pkey, EVP_PKEY_PUBLIC_KEY, params) <= 0)
+		goto out;
+
+	/* Extract RSA structure for compatibility with legacy textbook RSA code */
+#pragma GCC diagnostic push
+#pragma GCC diagnostic ignored "-Wdeprecated-declarations"
+	rsa_pub = EVP_PKEY_get1_RSA(pkey);
+#pragma GCC diagnostic pop
+
+out:
+	if (ctx)
+		EVP_PKEY_CTX_free(ctx);
+	if (pkey)
+		EVP_PKEY_free(pkey);
+	if (params)
+		OSSL_PARAM_free(params);
+	if (bld)
+		OSSL_PARAM_BLD_free(bld);
+	if (e)
+		BN_free(e);
+	if (n)
+		BN_free(n);
 
 	return rsa_pub;
 }
