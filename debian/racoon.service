[Unit]
Description=ipsec key exchange server
Requires=setkey.service
After=setkey.service

[Service]
Type=simple
EnvironmentFile=-/etc/default/racoon
RuntimeDirectory=racoon
ExecStart=-/usr/sbin/racoon -F $RACOON_ARGS
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target

